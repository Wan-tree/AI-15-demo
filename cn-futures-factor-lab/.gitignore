# Python 缓存和虚拟环境
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/

# 系统和编辑器文件
.DS_Store
.idea/
.vscode/

# 密钥与本地配置
.env
*.key
*.pem

# 数据库授权数据：目录结构保留，但内容不进入版本管理
data/raw/**
data/interim/**
data/processed/**
data/manifests/**
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/manifests/.gitkeep

# 运行产物
artifacts/**
!artifacts/.gitkeep

# Notebook 临时文件
.ipynb_checkpoints/

